# Required by the existing KYL dashboards as well as /download_layers.
REACT_APP_API_URL=https://geoserver.core-stack.org/api/v1
REACT_APP_GEOSERVER_URL=https://geoserver.core-stack.org:8443/geoserver/

# No GeoLibre variables are required for the official rolling deployment.
# Its tested fallback version and URL live in src/config/geolibre.config.js.
# Uncomment these only to override that source configuration at build time:
# REACT_APP_GEOLIBRE_VERSION=2.2.0
# REACT_APP_GEOLIBRE_URL=https://web.geolibre.app/
# REACT_APP_GEOLIBRE_STRICT_VERSION=false
# Optional MapLibre style URL. The default uses the same Google Satellite
# Hybrid tiles as the existing KYL maps.
# REACT_APP_GEOLIBRE_BASEMAP_STYLE_URL=https://maps.example.org/style.json

# To make the version value select an exact build, deploy GeoLibre at stable
# versioned paths and use this instead of REACT_APP_GEOLIBRE_URL:
# REACT_APP_GEOLIBRE_URL_TEMPLATE=https://geolibre.core-stack.org/{version}/
# REACT_APP_GEOLIBRE_STRICT_VERSION=true
